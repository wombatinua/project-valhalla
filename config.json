{
  "server": {
    "host": "0.0.0.0",
    "port": 8765
  },
  "comfy": {
    "url": "http://127.0.0.1:8188",
    "workflows_dir": "./workflows",
    "http_timeout_seconds": 15,
    "status_timeout_seconds": 2,
    "status_refresh_seconds": 10,
    "poll_interval_seconds": 1,
    "generation_timeout_seconds": 600,
    "preview_max_edge": 512,
    "workflow_source": "live",
    "profiles": {
      "production": "cielbleu-v2-innie-detailslider",
      "preview": "cielbleu-v2-innie-detailslider"
    }
  },
  "storage": {
    "output_dir": "./outputs",
    "proofs_dir": [],
    "output_format": "png",
    "jpeg_quality": 95,
    "strip_exif": true
  },
  "gallery": {
    "thumbnail_cache_mb": 512,
    "thumbnail_max_edge": 512
  },
  "interface": {
    "privacy": {
      "auto_cover_minutes": [
        5,
        15
      ]
    }
  },
  "limits": {
    "max_scene_attempts": 100,
    "max_storyboards": 20,
    "max_jobs": 40,
    "max_previews": 8
  }
}
